{
	"name": "goatide-bridge",
	"displayName": "GoatIDE Bridge",
	"description": "First-party bridge between the GoatIDE kernel sidecar and the editor process. Phase-4 Verification Canvas owner.",
	"version": "0.0.1",
	"publisher": "goatide",
	"engines": {
		"vscode": "^1.117.0"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configuration": {
			"title": "GoatIDE",
			"properties": {
				"goatide.contracts.highImpactAllowlist": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"/contracts/security/",
						"/contracts/api/",
						"/contracts/data/"
					],
					"description": "Path substrings that mark high-impact contract files; any cited ContractNode whose normalized contract_path contains one of these substrings forces the modal Verification Canvas tier. Path separators are normalized (Windows backslashes folded to forward slashes) before comparison."
				},
				"goatide.session.priority": {
					"type": "string",
					"default": "Quality-First",
					"description": "Current development session priority. Cited DecisionNodes whose derived_under_priority does not exact-match this value are flagged in the Verification Canvas as IntentDrift (Phase 7 Plan 07-05 / DRIFT-02).",
					"enum": [
						"Speed-First",
						"Quality-First",
						"Safety-First",
						"Cost-First"
					],
					"enumDescriptions": [
						"Optimize for shipping speed; quality + safety tradeoffs accepted.",
						"Optimize for code quality; speed tradeoffs accepted.",
						"Optimize for runtime safety + correctness; speed + cost tradeoffs accepted.",
						"Optimize for runtime cost; quality tradeoffs accepted."
					]
				}
			}
		},
		"commands": [
			{
				"command": "goatide.setSessionPriority",
				"title": "GoatIDE: Set Session Priority",
				"category": "GoatIDE"
			},
			{
				"command": "goatide.kernel.reconnect",
				"title": "GoatIDE: Reconnect Kernel",
				"category": "GoatIDE"
			},
			{
				"command": "goatide.mcp.reconnect",
				"title": "GoatIDE: Reconnect MCP Provider",
				"category": "GoatIDE"
			},
			{
				"command": "goatide.mcp.showStaleProviders",
				"title": "GoatIDE: Show Stale MCP Providers",
				"category": "GoatIDE"
			},
			{
				"command": "goatide.mcp.showSchemaDrift",
				"title": "GoatIDE: Show MCP Schema Drift",
				"category": "GoatIDE"
			},
			{
				"command": "goatide.harvester.showStaleSources",
				"title": "GoatIDE: Show Stale Telemetry Sources",
				"category": "GoatIDE"
			}
		]
	},
	"private": true,
	"scripts": {
		"build": "tsc -p . && node esbuild.config.mjs",
		"test": "node scripts/run-mocha-electron.cjs"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.6",
		"@vscode-elements/elements": "^1",
		"@vscode/codicons": "^0.0.36",
		"diff": "^7.0.0",
		"monaco-editor": "^0.52",
		"react": "^18.3",
		"react-dom": "^18.3",
		"ulid": "^2.3",
		"vscode-jsonrpc": "^8.2.1",
		"zod": "^3.25"
	},
	"devDependencies": {
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6",
		"@testing-library/react": "^16",
		"@types/cytoscape": "^3.21",
		"@types/diff": "^7.0.2",
		"@types/mocha": "^10",
		"@types/node": "^22.0.0",
		"@types/react": "^18.3",
		"@types/react-dom": "^18.3",
		"@types/sinon": "^10.0.2",
		"@types/vscode": "^1.117.0",
		"cytoscape": "^3.33.0",
		"cytoscape-fcose": "^2.2.0",
		"esbuild": "^0.24",
		"jsdom": "^25",
		"mocha": "^11",
		"tsx": "^4.21",
		"typescript": "^5.6.0"
	}
}

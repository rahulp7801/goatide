{
  "name": "@goatide/kernel",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "GoatIDE sidecar kernel — bitemporal graph substrate (Phase 2).",
  "main": "dist/main.js",
  "bin": {
    "goatide-cli": "./bin/goatide-cli"
  },
  "scripts": {
    "build": "tsc -p . && node -e \"const fs=require('node:fs');fs.cpSync('src/graph/migrations','dist/graph/migrations',{recursive:true,force:true});\"",
    "watch": "tsc -p . --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^13",
    "diff": "^7.0.0",
    "drizzle-orm": "^0.45.2",
    "ulid": "^2.3",
    "vscode-jsonrpc": "^8.2.1",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["vscode", "node", "mocha"],
		"typeRoots": ["./node_modules/@types"],
		"jsx": "react-jsx",
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": ["src/**/*"]
}
